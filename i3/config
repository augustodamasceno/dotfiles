# MOD KEY
# Mod1 = Alt | Mod4 = Super (Windows key)
set $mod Mod4

# FONT
# Cyberpunk-style fonts
#   Share Tech Mono  — narrow techy monospace
#   Orbitron         — geometric futuristic caps
#   Rajdhani         — angular sans with sharp edges
#   Noto Sans Mono   — fallback
font pango:Share Tech Mono 10

# VARIABLES
set $terminal     alacritty
set $browser      firefox
set $filemgr      pcmanfm
set $editor       nvim
set $lock         i3lock -c 0d0d1a
set $screenshot   scrot '%Y-%m-%d_%H-%M-%S.png' -e 'mv $f ~/Pictures/screenshots/'
set $screenclip   scrot -s '%Y-%m-%d_%H-%M-%S.png' -e 'mv $f ~/Pictures/screenshots/'
set $notifydaemon dunst

# WORKSPACES
set $ws1  "1: term"
set $ws2  "2: web"
set $ws3  "3: code"
set $ws4  "4: code2"
set $ws5  "5: vm"
set $ws6  "6: files"
set $ws7  "7: stack"
set $ws8  "8"
set $ws9  "9"
set $ws10 "10"

# COLORS (Cyberpunk palette)
set $base     #0d0d1a
set $mantle   #080810
set $crust    #050508
set $text     #e0e0ff
set $subtext  #a0a0cc
set $surface0 #1a1a2e
set $surface1 #16213e
set $overlay  #4a4a7a
set $blue     #00f0ff
set $lavender #bf00ff
set $mauve    #9b00ff
set $red      #ff003c
set $green    #00ff9f
set $yellow   #ffe600
set $peach    #ff6b00

# class                 border    bg        text      indicator  child_border
client.focused          $blue     $base     $text     $lavender  $blue
client.focused_inactive $surface0 $base     $subtext  $overlay   $surface0
client.unfocused        $surface0 $base     $overlay  $surface0  $surface0
client.urgent           $red      $red      $base     $red       $red
client.placeholder      $base     $base     $text     $base      $base
client.background       $base

# APPEARANCE
# Window border width (use 0 for no border)
default_border pixel 2
default_floating_border pixel 2
hide_edge_borders smart

# Gaps (requires i3-gaps or i3 >= 4.22)
gaps inner 8
gaps outer 4
smart_gaps on

# AUTOSTART
exec --no-startup-id dex --autostart --environment i3
exec --no-startup-id xss-lock --transfer-sleep-lock -- $lock --nofork
exec --no-startup-id nm-applet
exec --no-startup-id blueman-applet
exec --no-startup-id $notifydaemon
exec --no-startup-id picom --daemon
exec --no-startup-id feh --bg-scale ~/.config/i3/wallpaper.jpg
exec --no-startup-id numlockx on
exec --no-startup-id xset r rate 300 50
exec --no-startup-id /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1
exec --no-startup-id xrandr --output eDP-1 --auto --primary --output HDMI-1 --auto --left-of eDP-1

# KEYBINDINGS — APPS
bindsym $mod+Return       exec $terminal
bindsym $mod+shift+Return exec $terminal --class floating-term
bindsym $mod+b            exec $browser
bindsym $mod+e            exec $filemgr
bindsym $mod+F2           exec $browser
bindsym $mod+F3           exec $filemgr
# App launcher (rofi)
bindsym $mod+d exec --no-startup-id rofi -show drun -show-icons
# Window switcher
bindsym $mod+Tab exec --no-startup-id rofi -show window -show-icons
# Clipboard manager
bindsym $mod+v exec --no-startup-id rofi -modi "clipboard:greenclip print" -show clipboard -run-command '{cmd}'
# Emoji picker
bindsym $mod+period exec --no-startup-id rofimoji

# KEYBINDINGS — SYSTEM
bindsym $mod+shift+x exec $lock
bindsym Print        exec --no-startup-id $screenshot
bindsym $mod+Print   exec --no-startup-id $screenclip
# Notification controls (dunst)
bindsym $mod+grave           exec --no-startup-id dunstctl history-pop
bindsym $mod+shift+grave     exec --no-startup-id dunstctl close-all
bindsym $mod+ctrl+grave      exec --no-startup-id dunstctl action

# Display
bindsym $mod+shift+p       exec --no-startup-id xrandr --output eDP-1 --auto --primary --output HDMI-1 --auto --left-of eDP-1
bindsym $mod+ctrl+p        exec --no-startup-id xrandr --output eDP-1 --auto --primary --output HDMI-1 --auto --above eDP-1
bindsym $mod+ctrl+shift+p  exec --no-startup-id xrandr --output eDP-1 --auto --primary --output HDMI-1 --auto --right-of eDP-1
bindsym $mod+shift+m       exec --no-startup-id xrandr --output HDMI-1 --off --output eDP-1 --auto

# Keyboard layout
bindsym $mod+shift+b exec --no-startup-id setxkbmap br
bindsym $mod+shift+u exec --no-startup-id setxkbmap us intl

# KEYBINDINGS — AUDIO (PulseAudio / pipewire-pulse)
set $refresh_i3status killall -SIGUSR1 i3status
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +5%   && $refresh_i3status
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -5%   && $refresh_i3status
bindsym XF86AudioMute        exec --no-startup-id pactl set-sink-mute   @DEFAULT_SINK@ toggle && $refresh_i3status
bindsym XF86AudioMicMute     exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle
# Media keys
bindsym XF86AudioPlay  exec --no-startup-id playerctl play-pause
bindsym XF86AudioPause exec --no-startup-id playerctl pause
bindsym XF86AudioNext  exec --no-startup-id playerctl next
bindsym XF86AudioPrev  exec --no-startup-id playerctl previous
bindsym XF86AudioStop  exec --no-startup-id playerctl stop

# KEYBINDINGS — BRIGHTNESS
bindsym XF86MonBrightnessUp   exec --no-startup-id brightnessctl set +10%
bindsym XF86MonBrightnessDown exec --no-startup-id brightnessctl set 10%-

# KEYBINDINGS — WINDOW MANAGEMENT
# Kill focused window
bindsym $mod+q kill
bindsym $mod+shift+q kill

# Change focus (vim-style + arrows)
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right
bindsym $mod+Left  focus left
bindsym $mod+Down  focus down
bindsym $mod+Up    focus up
bindsym $mod+Right focus right

# Move focused window
bindsym $mod+shift+h move left
bindsym $mod+shift+j move down
bindsym $mod+shift+k move up
bindsym $mod+shift+l move right
bindsym $mod+shift+Left  move left
bindsym $mod+shift+Down  move down
bindsym $mod+shift+Up    move up
bindsym $mod+shift+Right move right

# Split orientation
bindsym $mod+ctrl+h split h
bindsym $mod+ctrl+v split v

# Fullscreen
bindsym $mod+f fullscreen toggle

# Layout
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+t layout toggle split

# Toggle floating
bindsym $mod+shift+space floating toggle
bindsym $mod+space        focus mode_toggle

# Focus parent / child container
bindsym $mod+a focus parent
bindsym $mod+z focus child

# KEYBINDINGS — SCRATCHPAD
bindsym $mod+shift+minus move scratchpad
bindsym $mod+minus       scratchpad show

# KEYBINDINGS — WORKSPACES
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

bindsym $mod+shift+1 move container to workspace number $ws1
bindsym $mod+shift+2 move container to workspace number $ws2
bindsym $mod+shift+3 move container to workspace number $ws3
bindsym $mod+shift+4 move container to workspace number $ws4
bindsym $mod+shift+5 move container to workspace number $ws5
bindsym $mod+shift+6 move container to workspace number $ws6
bindsym $mod+shift+7 move container to workspace number $ws7
bindsym $mod+shift+8 move container to workspace number $ws8
bindsym $mod+shift+9 move container to workspace number $ws9
bindsym $mod+shift+0 move container to workspace number $ws10

# Cycle workspaces
bindsym $mod+ctrl+Right workspace next
bindsym $mod+ctrl+Left  workspace prev

# Move workspace to output (monitor)
bindsym $mod+ctrl+shift+Right move workspace to output right
bindsym $mod+ctrl+shift+Left  move workspace to output left

# WORKSPACE ASSIGNMENTS
assign [class="Alacritty"]              $ws1
assign [class="firefox"]               $ws2
assign [class="Chromium"]              $ws2
assign [class="Code"]                  $ws3
assign [class="jetbrains-idea"]        $ws3
assign [class="Thunar"]                $ws6
assign [class="Nemo"]                  $ws6

# FLOATING WINDOW RULES
for_window [class="floating-term"]         floating enable, resize set 900 600, move position center
for_window [class="Pavucontrol"]           floating enable
for_window [class="Nm-connection-editor"]  floating enable
for_window [title="File Operation Progress"] floating enable, sticky enable
for_window [class="Lxappearance"]          floating enable, resize set 700 500
for_window [class="qt5ct"]                 floating enable, resize set 700 500
for_window [class="Blueman-manager"]       floating enable
for_window [class="Arandr"]               floating enable
for_window [class="feh"]                  floating enable
for_window [window_role="pop-up"]         floating enable
for_window [window_role="bubble"]         floating enable
for_window [window_role="dialog"]         floating enable
for_window [window_type="dialog"]         floating enable

# RESIZE MODE
mode "resize" {
    bindsym h resize shrink width  10 px or 5 ppt
    bindsym j resize grow   height 10 px or 5 ppt
    bindsym k resize shrink height 10 px or 5 ppt
    bindsym l resize grow   width  10 px or 5 ppt

    bindsym Left  resize shrink width  10 px or 5 ppt
    bindsym Down  resize grow   height 10 px or 5 ppt
    bindsym Up    resize shrink height 10 px or 5 ppt
    bindsym Right resize grow   width  10 px or 5 ppt

    bindsym Return mode "default"
    bindsym Escape mode "default"
    bindsym $mod+r mode "default"
}
bindsym $mod+r mode "resize"

# GAPS MODE
mode "gaps" {
    bindsym plus  gaps inner current plus  4
    bindsym minus gaps inner current minus 4
    bindsym 0     gaps inner current set   0

    bindsym shift+plus  gaps outer current plus  4
    bindsym shift+minus gaps outer current minus 4
    bindsym shift+0     gaps outer current set   0

    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+g mode "gaps"

# SYSTEM MODE (logout / reboot / shutdown / suspend / lock)
set $mode_system [l]ock  [e]xit  [s]uspend  [h]ibernate  [r]eboot  [S]hutdown
mode "$mode_system" {
    bindsym l exec --no-startup-id $lock,                            mode "default"
    bindsym e exec --no-startup-id i3-msg exit,                      mode "default"
    bindsym s exec --no-startup-id $lock && systemctl suspend,       mode "default"
    bindsym h exec --no-startup-id $lock && systemctl hibernate,     mode "default"
    bindsym r exec --no-startup-id systemctl reboot,                 mode "default"
    bindsym shift+s exec --no-startup-id systemctl poweroff -i,      mode "default"

    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+shift+e mode "$mode_system"

# I3 MANAGEMENT
bindsym $mod+shift+c reload
bindsym $mod+shift+r restart

# STATUS BAR
bar {
    status_command i3status --config ~/.config/i3status/config
    position top
    tray_output primary
    tray_padding 4

    colors {
        background         $base
        statusline         $blue
        separator          $lavender

        # class             border    bg        text
        focused_workspace   $blue     $blue     $base
        active_workspace    $surface0 $surface0 $text
        inactive_workspace  $base     $base     $overlay
        urgent_workspace    $red      $red      $base
        binding_mode        $lavender $lavender $base
    }
}

# MOUSE BEHAVIOR
# Use $mod + mouse to drag floating windows
floating_modifier $mod
# Middle-click on title bar to kill window
bindsym --release button2 kill
# Do not follow mouse focus
focus_follows_mouse no
# Warp mouse to focused window
mouse_warping output
